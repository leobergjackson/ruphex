BITSO_API_KEY=
BITSO_API_SECRET=
NEXT_PUBLIC_CONTRACT_ADDRESS=0x<deployed_recibo_contract>
NEXT_PUBLIC_USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
NEXT_PUBLIC_CHAIN_ID=421614
NEXT_PUBLIC_ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=<walletconnect_project_id>
GROQ_API_KEY=<groq_api_key>
GROQ_MODEL=llama-3.3-70b-versatile

# RARE Protocol — receipts minted as provenance NFTs (see RARE.md).
# The signing key lives in ~/.rare/config.json via `rare configure`, NOT here.
RARE_CHAIN=sepolia
RARE_COLLECTION_ADDRESS=0x<from_rare_collection_deploy>

# `npm run proof` — captures real onchain proof hashes. Needs a FUNDED Arbitrum Sepolia key
# (ETH for gas + USDC to send). Throwaway/testnet only — never a mainnet key.
PROOF_PRIVATE_KEY=0x<funded_arbitrum_sepolia_key>
PROOF_RECIPIENT=0x<creator_wallet_that_gets_paid>
PROOF_AMOUNT=1
