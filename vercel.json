{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "app/api/chat/route.ts": { "maxDuration": 60 },
    "app/api/transcribe/route.ts": { "maxDuration": 30 },
    "app/api/tts/route.ts": { "maxDuration": 30 },
    "app/api/notify/route.ts": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,xi-api-key" }
      ]
    }
  ]
}
