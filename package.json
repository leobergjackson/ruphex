    "mipd": "^0.0.7",
    "next": "16.2.6",
    "next-intl": "^4.13.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
